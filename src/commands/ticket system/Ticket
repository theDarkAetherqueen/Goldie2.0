const {
    EmbedBuilder,
    ActionRowBuilder,
    StringSelectMenuBuilder,
    ButtonBuilder,
    ButtonStyle,
    ChannelType,
    PermissionsBitField
} = require('discord.js');

module.exports = (client) => {

    // ====================== TICKET COMMAND ======================
    client.on('interactionCreate', async interaction => {
        if (!interaction.isChatInputCommand()) return;

        if (interaction.commandName === 'ticket') {
            const embed = new EmbedBuilder()
                .setTitle('🎟️ Support Ticket System')
                .setDescription('Click the button below to create a new ticket.')
                .setColor(0x5865F2);

            const button = new ButtonBuilder()
                .setCustomId('create_ticket_btn')
                .setLabel('Create Ticket')
                .setEmoji('📩')
                .setStyle(ButtonStyle.Primary);

            const row = new ActionRowBuilder().addComponents(button);

            await interaction.reply({ embeds: [embed], components: [row] });
        }
    });

    // ====================== BUTTON HANDLER ======================
    client.on('interactionCreate', async interaction => {
        if (interaction.isButton() && interaction.customId === 'create_ticket_btn') {
            await showCategoryDropdown(interaction);
        }

        if (interaction.isButton() && interaction.customId.startsWith('close_ticket_')) {
            await closeTicket(interaction);
        }
    });

    // ====================== DROPDOWN HANDLERS ======================
    client.on('interactionCreate', async interaction => {
        if (!interaction.isStringSelectMenu()) return;

        if (interaction.customId === 'ticket_category') {
            client.ticketData = client.ticketData || new Map();
            client.ticketData.set(interaction.user.id, {
                category: interaction.values[0]
            });

            await showPriorityDropdown(interaction);
        }

        if (interaction.customId === 'ticket_priority') {
            await createTicket(interaction);
        }
    });

    // ====================== FUNCTIONS ======================
    async function showCategoryDropdown(interaction) {
        const categoryMenu = new StringSelectMenuBuilder()
            .setCustomId('ticket_category')
            .setPlaceholder('Select Support Category')
            .addOptions([
                { label: 'General Support', value: 'general', emoji: '❓' },
                { label: 'Technical Issue', value: 'technical', emoji: '🔧' },
                { label: 'Billing & Payments', value: 'billing', emoji: '💰' },
                { label: 'Account Issue', value: 'account', emoji: '👤' },
                { label: 'Bug Report', value: 'bug', emoji: '🐛' },
                { label: 'Feature Request', value: 'feature', emoji: '💡' },
                { label: 'Complaint', value: 'complaint', emoji: '⚠️' },
                { label: 'Other', value: 'other', emoji: '📌' }
            ]);

        const row = new ActionRowBuilder().addComponents(categoryMenu);

        await interaction.reply({
            content: '**Please select a category for your ticket:**',
            components: [row],
            ephemeral: true
        });
    }

    async function showPriorityDropdown(interaction) {
        const priorityMenu = new StringSelectMenuBuilder()
            .setCustomId('ticket_priority')
            .setPlaceholder('Select Priority Level')
            .addOptions([
                { label: 'Low', value: 'low', emoji: '🟢' },
                { label: 'Medium', value: 'medium', emoji: '🟡' },
                { label: 'High', value: 'high', emoji: '🟠' },
                { label: 'Urgent', value: 'urgent', emoji: '🔴' }
            ]);

        const row = new ActionRowBuilder().addComponents(priorityMenu);

        await interaction.update({
            content: '**Category selected! Now select priority:**',
            components: [row],
            ephemeral: true
        });
    }

    async function createTicket(interaction) {
        const userData = client.ticketData?.get(interaction.user.id);
        if (!userData) {
            return interaction.update({ content: '❌ Session expired. Please try again.', components: [] });
        }

        const category = userData.category;
        const priority = interaction.values[0];

        try {
            const ticketChannel = await interaction.guild.channels.create({
                name: `ticket-${interaction.user.username}`,
                type: ChannelType.GuildText,
                permissionOverwrites: [
                    {
                        id: interaction.guild.id,
                        deny: [PermissionsBitField.Flags.ViewChannel]
                    },
                    {
                        id: interaction.user.id,
                        allow: [
                            PermissionsBitField.Flags.ViewChannel,
                            PermissionsBitField.Flags.SendMessages,
                            PermissionsBitField.Flags.ReadMessageHistory
                        ]
                    }
                ]
            });

            const color = priority === 'urgent' ? 0xFF0000 :
                         priority === 'high' ? 0xFF8800 :
                         priority === 'medium' ? 0xFFCC00 : 0x00FF00;

            const embed = new EmbedBuilder()
                .setTitle('🎟️ New Support Ticket')
                .setColor(color)
                .addFields(
                    { name: 'User', value: `${interaction.user}`, inline: true },
                    { name: 'Category', value: category.toUpperCase(), inline: true },
                    { name: 'Priority', value: priority.toUpperCase(), inline: true }
                )
                .setTimestamp();

            const closeBtn = new ButtonBuilder()
                .setCustomId(`close_ticket_${ticketChannel.id}`)
                .setLabel('Close Ticket')
                .setEmoji('🔒')
                .setStyle(ButtonStyle.Danger);

            const row = new ActionRowBuilder().addComponents(closeBtn);

            await ticketChannel.send({
                content: `${interaction.user}`,
                embeds: [embed],
                components: [row]
            });

            await interaction.update({
                content: `✅ **Your ticket has been created!**\n→ ${ticketChannel}`,
                components: []
            });

            client.ticketData.delete(interaction.user.id);

        } catch (err) {
            console.error(err);
            await interaction.update({ content: '❌ Failed to create ticket.', components: [] });
        }
    }

    async function closeTicket(interaction) {
        await interaction.reply({ content: '🔒 Closing ticket in 3 seconds...', ephemeral: true });
        setTimeout(() => interaction.channel.delete().catch(() => {}), 3000);
    }
};
