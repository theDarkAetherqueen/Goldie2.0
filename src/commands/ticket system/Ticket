const { Client, GatewayIntentBits, EmbedBuilder, ActionRowBuilder, StringSelectMenuBuilder, ButtonBuilder, ButtonStyle, PermissionsBitField, ChannelType } = require('discord.js');
const fs = require('fs');
const path = require('path');

// =========================
// CONFIG
// =========================
const OPEN_CATEGORY_NAME = "Tickets";
const CLOSED_CATEGORY_NAME = "Closed Tickets";
const CHANNEL_PREFIX = "ticket";

// Optional: lock staff to specific role IDs.
// If empty, staff = anyone with kick/ban perms (and optionally manage_channels).
const STAFF_ROLE_IDS = [];
const PING_KICK_BAN_ROLES = true;
const ALLOW_MANAGE_CHANNELS_AS_STAFF = true;

const DATA_DIR = "data";
const DB_PATH = path.join(DATA_DIR, "tickets.json");

const TICKET_OPTIONS = [
    { label: "General Questions", emoji: "📋", value: "general-questions" },
    { label: "Report User", emoji: "🛠️", value: "report-user" },
    { label: "Report Bug", emoji: "🧰", value: "report-bug" },
    { label: "Application Partner", emoji: "🤝", value: "application-partner" },
    { label: "Application Serverteam", emoji: "🛡️", value: "application-serverteam" },
    { label: "Discord Help", emoji: "🧩", value: "discord-help" },
    { label: "Other", emoji: "❓", value: "other" },
];

// =========================
// STORAGE
// =========================
function ensureDataDir() {
    if (!fs.existsSync(DATA_DIR)) fs.mkdirSync(DATA_DIR, { recursive: true });
}

function loadDB() {
    ensureDataDir();
    if (!fs.existsSync(DB_PATH)) return { tickets: {} };
    try {
        return JSON.parse(fs.readFileSync(DB_PATH, 'utf-8'));
    } catch (e) {
        return { tickets: {} };
    }
}

function saveDB(db) {
    ensureDataDir();
    fs.writeFileSync(DB_PATH, JSON.stringify(db, null, 2), 'utf-8');
}

function nowISO() {
    return new Date().toISOString();
}

function slugify(text) {
    text = text.toLowerCase().trim();
    text = text.replace(/[^a-z0-9\s-]/g, "");
    text = text.replace(/\s+/g, "-");
    text = text.replace(/-{2,}/g, "-");
    return (text.slice(0, 32).replace(/^-|-$/g, "") || "ticket");
}

// =========================
// STAFF + PINGS
// =========================
function isStaff(member) {
    if (STAFF_ROLE_IDS.length > 0) {
        return member.roles.cache.some(role => STAFF_ROLE_IDS.includes(role.id));
    }
    const perms = member.permissions;
    if (perms.has(PermissionsBitField.Flags.KickMembers) || perms.has(PermissionsBitField.Flags.BanMembers)) return true;
    if (ALLOW_MANAGE_CHANNELS_AS_STAFF && perms.has(PermissionsBitField.Flags.ManageChannels)) return true;
    return false;
}

function getKickBanRoleMentions(guild) {
    const roles = guild.roles.cache
        .filter(role => !role.managed && (role.permissions.has(PermissionsBitField.Flags.KickMembers) || role.permissions.has(PermissionsBitField.Flags.BanMembers)))
        .map(role => role.toString());

    if (roles.length === 0) return "";
    const joined = roles.slice(0, 15).join(" ");
    return roles.length > 15 ? joined + " …" : joined;
}

async function getOrCreateCategory(guild, name) {
    let cat = guild.channels.cache.find(c => c.name === name && c.type === ChannelType.GuildCategory);
    if (cat) return cat;

    try {
        return await guild.channels.create({
            name,
            type: ChannelType.GuildCategory,
            reason: "Ticket system category auto-created"
        });
    } catch (err) {
        console.error(err);
        return null;
    }
}

// =========================
// TICKET CONTROLS
// =========================
async function handleClaim(interaction) {
    if (!interaction.guild || !interaction.member) return interaction.reply({ content: "Server-only.", ephemeral: true });
    if (!isStaff(interaction.member)) return interaction.reply({ content: "Staff only.", ephemeral: true });

    const channel = interaction.channel;
    if (channel.type !== ChannelType.GuildText) return interaction.reply({ content: "Not a ticket channel.", ephemeral: true });

    const db = loadDB();
    const ticket = db.tickets[channel.id];
    if (!ticket) return interaction.reply({ content: "Ticket data not found.", ephemeral: true });
    if (ticket.status !== "open") return interaction.reply({ content: "This ticket is not open.", ephemeral: true });
    if (ticket.claimed_by) {
        return interaction.reply({ content: ticket.claimed_by === interaction.user.id ? "You already claimed this ticket." : "This ticket is already claimed.", ephemeral: true });
    }

    ticket.claimed_by = interaction.user.id;
    ticket.claimed_at = nowISO();
    db.tickets[channel.id] = ticket;
    saveDB(db);

    const owner = interaction.guild.members.cache.get(ticket.user_id);
    let dmOk = false;
    if (owner) {
        try {
            await owner.send(`Your ticket has been **claimed** by **${interaction.user.displayName}** in **${interaction.guild.name}**.\nPlease respond in your ticket channel: #${channel.name}`);
            dmOk = true;
        } catch {}
    }

    await interaction.reply({
        content: `✅ Ticket claimed by ${interaction.user}.` + (dmOk ? "" : " (Could not DM the user.)"),
        allowedMentions: { users: true, roles: false, everyone: false }
    });
}

async function handleClose(interaction) {
    if (!interaction.guild || !interaction.member) return interaction.reply({ content: "Server-only.", ephemeral: true });
    if (!isStaff(interaction.member)) return interaction.reply({ content: "Staff only.", ephemeral: true });

    const channel = interaction.channel;
    if (channel.type !== ChannelType.GuildText) return interaction.reply({ content: "Not a ticket channel.", ephemeral: true });

    const db = loadDB();
    const ticket = db.tickets[channel.id];
    if (!ticket) return interaction.reply({ content: "Ticket data not found.", ephemeral: true });
    if (ticket.status === "closed") return interaction.reply({ content: "Ticket already closed.", ephemeral: true });

    const closedCat = await getOrCreateCategory(interaction.guild, CLOSED_CATEGORY_NAME);
    if (!closedCat) return interaction.reply({ content: `Can’t create/find \`${CLOSED_CATEGORY_NAME}\`. Create it manually.`, ephemeral: true });

    ticket.status = "closed";
    ticket.closed_by = interaction.user.id;
    ticket.closed_at = nowISO();
    db.tickets[channel.id] = ticket;
    saveDB(db);

    const overwrites = new Map(channel.permissionOverwrites.cache);
    const owner = interaction.guild.members.cache.get(ticket.user_id);
    if (owner) overwrites.set(owner.id, { ViewChannel: false });

    overwrites.set(interaction.guild.id, { ViewChannel: false });
    overwrites.set(interaction.guild.members.me.id, {
        ViewChannel: true,
        SendMessages: true,
        ManageChannels: true,
        ReadMessageHistory: true
    });

    if (STAFF_ROLE_IDS.length > 0) {
        for (const rid of STAFF_ROLE_IDS) {
            const role = interaction.guild.roles.cache.get(rid);
            if (role) {
                overwrites.set(role.id, { ViewChannel: true, SendMessages: true, ReadMessageHistory: true });
            }
        }
    }

    const newName = `closed-${channel.name}`.slice(0, 95);

    await channel.edit({
        name: newName,
        parent: closedCat,
        permissionOverwrites: Array.from(overwrites.values()),
    });

    await interaction.reply({ content: "🔒 Ticket closed and moved to Closed Tickets.", ephemeral: true });
}

// =========================
// INTERACTION HANDLER
// =========================
async function handleInteraction(interaction) {
    if (!interaction.isButton() && !interaction.isStringSelectMenu()) return;

    const customId = interaction.customId;

    if (customId === "tickets:claim") return handleClaim(interaction);
    if (customId === "tickets:close") return handleClose(interaction);

    if (customId === "tickets:reason_select") {
        const reasonValue = interaction.values[0];
        const reasonLabel = TICKET_OPTIONS.find(opt => opt.value === reasonValue).label;

        const prioritySelect = new StringSelectMenuBuilder()
            .setCustomId(`tickets:priority_select:${reasonValue}:${reasonLabel}`)
            .setPlaceholder("Select ticket priority...")
            .addOptions([
                { label: "Low", value: "low", emoji: "🟢" },
                { label: "Medium", value: "medium", emoji: "🟡" },
                { label: "High", value: "high", emoji: "🔴" },
            ]);

        const row = new ActionRowBuilder().addComponents(prioritySelect);

        return interaction.reply({
            content: `**Reason:** ${reasonLabel}\nPlease select the priority for this ticket:`,
            components: [row],
            ephemeral: true
        });
    }

    if (customId.startsWith("tickets:priority_select:")) {
        const parts = customId.split(":");
        const reasonValue = parts[2];
        const reasonLabel = parts[3];
        const priority = interaction.values[0];

        const guild = interaction.guild;
        const member = interaction.member;

        const db = loadDB();

        // Prevent multiple open tickets
        for (const [chId, t] of Object.entries(db.tickets)) {
            if (t.guild_id === guild.id && t.user_id === member.id && t.status === "open") {
                const ch = guild.channels.cache.get(chId);
                if (ch) return interaction.reply({ content: `You already have an open ticket: ${ch}`, ephemeral: true });
            }
        }

        const openCat = await getOrCreateCategory(guild, OPEN_CATEGORY_NAME);
        if (!openCat) return interaction.reply({ content: `Can’t create/find \`${OPEN_CATEGORY_NAME}\`. Create it manually.`, ephemeral: true });

        const name = `${CHANNEL_PREFIX}-${slugify(member.displayName)}-${slugify(reasonValue)}`.slice(0, 95);

        const overwrites = [
            { id: guild.id, deny: [PermissionsBitField.Flags.ViewChannel] },
            { id: member.id, allow: [PermissionsBitField.Flags.ViewChannel, PermissionsBitField.Flags.SendMessages, PermissionsBitField.Flags.ReadMessageHistory, PermissionsBitField.Flags.AttachFiles, PermissionsBitField.Flags.EmbedLinks] },
            { id: guild.members.me.id, allow: [PermissionsBitField.Flags.ViewChannel, PermissionsBitField.Flags.SendMessages, PermissionsBitField.Flags.ManageChannels, PermissionsBitField.Flags.ReadMessageHistory] },
        ];

        if (STAFF_ROLE_IDS.length > 0) {
            for (const rid of STAFF_ROLE_IDS) {
                const role = guild.roles.cache.get(rid);
                if (role) overwrites.push({ id: role.id, allow: [PermissionsBitField.Flags.ViewChannel, PermissionsBitField.Flags.SendMessages, PermissionsBitField.Flags.ReadMessageHistory] });
            }
        }

        const channel = await guild.channels.create({
            name,
            type: ChannelType.GuildText,
            parent: openCat,
            permissionOverwrites: overwrites,
            reason: `Ticket opened by ${member.user.tag} (${member.id})`
        });

        db.tickets[channel.id] = {
            guild_id: guild.id,
            user_id: member.id,
            reason: reasonLabel,
            reason_key: reasonValue,
            priority: priority,
            status: "open",
            opened_at: nowISO(),
            claimed_by: null,
            claimed_at: null,
            closed_by: null,
            closed_at: null,
        };
        saveDB(db);

        const staffPing = PING_KICK_BAN_ROLES ? getKickBanRoleMentions(guild) : "";

        const embed = new EmbedBuilder()
            .setTitle("Support Ticket Opened")
            .setDescription(
                `**Reason:** ${reasonLabel}\n` +
                `**Priority:** ${priority.toUpperCase()}\n\n` +
                `${member} — staff will be with you shortly.\n` +
                `Please describe your issue clearly and include screenshots/video if needed.`
            )
            .setColor(0x5865F2)
            .setFooter({ text: "Staff: Claim to take this ticket, Close when finished." });

        const row = new ActionRowBuilder().addComponents(
            new ButtonBuilder().setCustomId("tickets:claim").setLabel("Claim").setStyle(ButtonStyle.Primary).setEmoji("🧷"),
            new ButtonBuilder().setCustomId("tickets:close").setLabel("Close").setStyle(ButtonStyle.Danger).setEmoji("🔒")
        );

        await channel.send({
            content: staffPing || undefined,
            embeds: [embed],
            components: [row],
            allowedMentions: { parse: ["users", "roles"] }
        });

        await interaction.update({ content: `✅ Ticket created: ${channel}`, components: [] });
    }
}

// =========================
// BOT SETUP
// =========================
const client = new Client({
    intents: [GatewayIntentBits.Guilds, GatewayIntentBits.GuildMembers, GatewayIntentBits.GuildMessages, GatewayIntentBits.MessageContent]
});

client.once('ready', () => {
    console.log(`✅ Ticket bot is online as ${client.user.tag}`);
});

client.on('interactionCreate', async interaction => {
    if (interaction.isCommand()) {
        if (interaction.commandName === "ticket_setup") {
            if (!interaction.memberPermissions.has(PermissionsBitField.Flags.Administrator)) {
                return interaction.reply({ content: "Admin only.", ephemeral: true });
            }

            const embed = new EmbedBuilder()
                .setTitle("Need help? Select an option below to open a support ticket.")
                .setColor(0x5865F2);

            const select = new StringSelectMenuBuilder()
                .setCustomId("tickets:reason_select")
                .setPlaceholder("Select your ticket reason...")
                .addOptions(TICKET_OPTIONS.map(opt => ({
                    label: opt.label,
                    value: opt.value,
                    emoji: opt.emoji
                })));

            const row = new ActionRowBuilder().addComponents(select);

            await interaction.reply({ embeds: [embed], components: [row] });
        }
        return;
    }

    if (interaction.isButton() || interaction.isStringSelectMenu()) {
        try {
            await handleInteraction(interaction);
        } catch (err) {
            console.error(err);
            if (!interaction.replied && !interaction.deferred) {
                await interaction.reply({ content: "An error occurred.", ephemeral: true });
            }
        }
    }
});
